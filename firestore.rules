// firestore.rules
// ─────────────────────────────────────────────────────────────────────────────
// HOW TO DEPLOY:
//   Firebase Console → Firestore Database → Rules tab → paste this → Publish
// ─────────────────────────────────────────────────────────────────────────────
//
// Collections:
//   projects/{id}    → { title, description, images[], imageUrl, categoryId, createdAt }
//   categories/{id}  → { name }
//   users/{uid}      → { email, role: "admin" | string }
//
// Admin check uses the verified email from the Firebase Auth JWT token.
// This avoids the Firestore-read-in-rule catch-22 (circular permission issue).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check via Firebase Auth JWT email ─────────────────────────────
    // Change the email below to your actual admin email address.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == "truquenco@gmail.com";
    }

    // ── Portfolio projects ──────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read:                   if true;       // Anyone can view
      allow create, update, delete: if isAdmin();  // Only admin can modify
    }

    // ── Categories ──────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read:                   if true;       // Anyone can view
      allow create, update, delete: if isAdmin();  // Only admin can modify
    }

    // ── News ────────────────────────────────────────────────────────────────
    match /news/{newsId} {
      allow read:                   if true;       // Anyone can view
      allow create, update, delete: if isAdmin();  // Only admin can modify
    }

    // ── Team ────────────────────────────────────────────────────────────────
    match /team/{memberId} {
      allow read:                   if true;       // Anyone can view
      allow create, update, delete: if isAdmin();  // Only admin can modify
    }

    // ── Users (roles) ───────────────────────────────────────────────────────
    // Admin can manage all user role documents.
    // A logged-in user can read their own document (for role display).
    match /users/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
